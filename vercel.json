{
  "version": 2,
  "cleanUrls": true,
  "headers": [
    { "source": "/(.*)\\.(png|jpg|jpeg|mp4|mp3|webp)", "headers": [{"key":"Cache-Control","value":"public,max-age=31536000,immutable"}] },
    { "source": "/index.html", "headers": [{"key":"Cache-Control","value":"public,max-age=0,must-revalidate"}] }
  ]
}
